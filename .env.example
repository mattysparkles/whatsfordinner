# PantryPilot local environment template
# Copy to `.env` for your own reference; runtime is controlled with --dart-define.

APP_ENV=dev
USE_MOCKS=true

RECIPE_API_BASE_URL=https://example.com/recipes
RECIPE_API_KEY=replace_me

VISION_API_BASE_URL=https://example.com/vision
VISION_API_KEY=replace_me

# Optional metadata for About screen / CI builds
APP_VERSION=0.1.0+1
BUILD_DATE=2026-03-30
