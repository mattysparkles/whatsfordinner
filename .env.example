# PantryPilot local environment template
# Copy to `.env` for your own reference; runtime is controlled with --dart-define.

APP_ENV=dev
USE_MOCKS=true

# Mobile app -> backend gateway URL
GATEWAY_API_BASE_URL=http://localhost:8000

# Legacy values kept for compatibility; production now routes AI calls through gateway.
RECIPE_API_BASE_URL=https://example.com/recipes
RECIPE_API_KEY=replace_me
VISION_API_BASE_URL=https://example.com/vision
VISION_API_KEY=replace_me

# Optional metadata for About screen / CI builds
APP_VERSION=0.1.0+1
BUILD_DATE=2026-03-30

# Backend secrets (set in backend environment, NEVER in mobile app)
PANTRY_GATEWAY_OPENAI_API_KEY=replace_me
PANTRY_GATEWAY_OPENAI_MODEL_VISION=gpt-4.1-mini
PANTRY_GATEWAY_OPENAI_MODEL_RECIPE=gpt-4.1-mini
PANTRY_GATEWAY_OPENAI_BASE_URL=https://api.openai.com/v1
PANTRY_GATEWAY_INSTACART_PARTNER_ID=replace_me
PANTRY_GATEWAY_INSTACART_API_KEY=replace_me
PANTRY_GATEWAY_RATE_LIMIT_PER_MINUTE=60
